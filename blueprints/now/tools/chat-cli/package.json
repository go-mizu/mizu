{
  "name": "chat-now",
  "version": "0.1.0",
  "description": "TUI + CLI for chat.go-mizu.workers.dev",
  "type": "module",
  "bin": {
    "chat-now": "./bin/chat-now.js"
  },
  "exports": {
    ".": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
