{
  "name": "storage-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute storage-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute storage-db --remote --file=schema.sql",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "hono": "^4.12.8",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.76.0"
  }
}
