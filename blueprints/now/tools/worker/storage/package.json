{
  "name": "storage-worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create storage-db",
    "db:migrate": "wrangler d1 execute storage-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute storage-db --remote --file=schema.sql"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "marked": "^17.0.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.75.0"
  }
}
