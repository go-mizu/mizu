cmd_version() {
  echo "storage $VERSION"
}

# ── Main ─────────────────────────────────────────────────────────────────

main() {
  load_config

  # Parse global flags
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json|-j) JSON_OUTPUT=1; shift ;;
      --quiet|-q) QUIET=1; shift ;;
      --token|-t) TOKEN="$2"; shift 2 ;;
      --endpoint|-e) ENDPOINT="$2"; shift 2 ;;
      --no-color) shift ;; # already handled above
      --version|-V) cmd_version; exit 0 ;;
      --help|-h)
        if [[ ${#args[@]} -eq 0 ]]; then
          cmd_help; exit 0
        fi
        args+=("$1"); shift ;;
      *) args+=("$1"); shift ;;
    esac
  done

  if [[ ${#args[@]} -eq 0 ]]; then
    cmd_help
    exit 0
  fi

  local cmd="${args[0]}"
  local cmd_args=()
  if [[ ${#args[@]} -gt 1 ]]; then
    cmd_args=("${args[@]:1}")
  fi

  case "$cmd" in
    login)    cmd_login "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    logout)   cmd_logout ;;
    token)    cmd_token "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    ls|list)  cmd_ls "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    put|upload|push) cmd_put "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    get|download|pull) cmd_get "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    cat|read) cmd_cat "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    rm|delete|del) cmd_rm "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    mv|move|rename) cmd_mv "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    cp|copy)  cmd_cp "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    share|sign) cmd_share "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    info)     cmd_info "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    search|find) cmd_search "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    stats)    cmd_stats ;;
    bucket)   cmd_bucket "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    key|keys) cmd_key "${cmd_args[@]+"${cmd_args[@]}"}" ;;
    help)     cmd_help ;;
    version)  cmd_version ;;
    *)
      die "unknown command: $cmd" \
        "Run '${_bold}storage help${_reset}' for available commands" "" 2
      ;;
  esac
}

main "$@"
