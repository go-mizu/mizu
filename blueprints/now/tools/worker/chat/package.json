{
  "name": "chat-worker",
  "private": true,
  "scripts": {
    "build:docs": "node scripts/build-docs.mjs",
    "build:avatars": "node scripts/build-avatars.mjs",
    "build": "npm run build:docs && npm run build:avatars",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:create": "wrangler d1 create chat-db",
    "db:migrate": "wrangler d1 execute chat-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute chat-db --remote --file=schema.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bot": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "marked": "^17.0.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.74.0"
  }
}
