{
  "name": "chat-worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create chat-db",
    "db:migrate": "wrangler d1 execute chat-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute chat-db --remote --file=schema.sql",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.11.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@cloudflare/workers-types": "^4.20260205.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.63.0"
  }
}
