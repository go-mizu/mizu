{
  "name": "browser-worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create browser-db",
    "db:migrate": "wrangler d1 execute browser-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute browser-db --remote --file=schema.sql",
    "queue:create": "wrangler queues create browser-crawl"
  },
  "dependencies": {
    "hono": "^4.11.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260205.0",
    "wrangler": "^4.63.0",
    "typescript": "^5.8.3"
  }
}
